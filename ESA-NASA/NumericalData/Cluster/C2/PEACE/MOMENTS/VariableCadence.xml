            <ResourceName>PEACE Moments data from the HEEA and/or LEEA sensors</ResourceName>
            <AlternateName>C2_CP_PEA_MOMENTS</AlternateName>
            <ReleaseDate>2026-03-13T00:00:00</ReleaseDate>
            <RevisionHistory>
                <RevisionEvent>
                    <ReleaseDate>2026-03-13T00:00:00</ReleaseDate>
                    <Note>Initial release of metadata</Note>
